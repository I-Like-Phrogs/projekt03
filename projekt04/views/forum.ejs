<%- include("head.partial.ejs") %>
    <main>
    <a href="/">powrót</a>
    <% if (user) { %>
      <div class="user-info">
        <p>Zalogowany jako: <strong><%= user.login %></strong></p>
        <a href="/logout" class="auth-btn">Wyloguj</a>
      </div>
    <% } else { %>
      <div class="auth-links">
        <a href="/login" class="auth-btn">Zaloguj się</a>
        <a href="/register" class="auth-btn">Zarejestruj się</a>
      </div>
    <% } %>
      <h1>Posty użytkowników</h1>
      <p class="new_post_link"><% if (user) { %>Stwórz własny <a href="/create">post</a><% } else { %><a href="/login">Zaloguj się</a> aby utworzyć post<% } %></p>
      <div class="posts-container">
        <% posts.forEach(function(post){ %>
          <div class="post">
              <div class="post-header">
                <h2><%= post.title %></h2>
                <b><%= post.author %></b>
              </div>
              <p><%= post.text %></p>
              <div class="post-actions">
                <% if (post.canEdit) { %>
                  <a href="/edit/<%= post.id %>" class="post-btn edit-btn">Edytuj</a>
                <% } %>
                <% if (post.canDelete) { %>
                  <a href="/delete/<%= post.id %>" class="post-btn delete-btn">Usuń</a>
                <% } %>
              </div>
          </div>
        <% }) %>
      </div>
      
      <div class="pagination-controls">
        <% if (currentPage > 1) { %>
          <a href="/forum?page=<%= parseInt(currentPage) - 1 %>" class="pagination-btn">← Poprzednia strona</a>
        <% } %>
        
        <span class="page-counter">Strona <%= currentPage %></span>
        
        <% if (hasNextPage) { %>
          <a href="/forum?page=<%= parseInt(currentPage) + 1 %>" class="pagination-btn">Następna strona →</a>
        <% } %>
      </div>
    </main>
<%- include("foot.partial.ejs") %>